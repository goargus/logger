# Auth0 Configuration (existing development tenant)
AUTH0_DOMAIN=dev-ohuspam6fnmh4tgt.us.auth0.com
AUTH0_AUDIENCE=logger

# Existing Auth0 Application (same as development frontend)
# NOTE: Resource Owner Password Grant must be enabled for e2e testing
AUTH0_E2E_CLIENT_ID=2H45P97qEyC9HfiKFj8FOvb8DnSOgFwY
AUTH0_E2E_CLIENT_SECRET=<get-from-auth0-dashboard>

# =============================================================================
# TEST USERS
# =============================================================================
# These users must exist in Auth0 with Resource Owner Password Grant enabled.
# Create them in Auth0 Dashboard > User Management > Users

# Admin User - System administrator with full access
E2E_ADMIN_EMAIL=admin@test.local
E2E_ADMIN_PASSWORD=<auth0-password>
E2E_ADMIN_IDP_SUBJECT=auth0|<user-id>

# Missionary User - Regular user, can only see/modify own activities
E2E_MISSIONARY_EMAIL=missionary@test.local
E2E_MISSIONARY_PASSWORD=<auth0-password>
E2E_MISSIONARY_IDP_SUBJECT=auth0|<user-id>

# Pastor User - Hierarchy permissions, can see subordinate activities
E2E_PASTOR_EMAIL=pastor@test.local
E2E_PASTOR_PASSWORD=<auth0-password>
E2E_PASTOR_IDP_SUBJECT=auth0|<user-id>

# President User - Association-level access, entity-wide permissions
E2E_PRESIDENT_EMAIL=president@test.local
E2E_PRESIDENT_PASSWORD=<auth0-password>
E2E_PRESIDENT_IDP_SUBJECT=auth0|<user-id>

# =============================================================================
# ENVIRONMENT URLS
# =============================================================================
E2E_API_URL=http://localhost:3001
E2E_FRONTEND_URL=http://localhost:8081

# =============================================================================
# TEST EXECUTION OPTIONS
# =============================================================================
E2E_HEADLESS=true
E2E_SLOW_MO=0
