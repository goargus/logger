API_BASE_URL=https://your-render-service.onrender.com
REDIRECT_URI=https://secretary-frontend-dev.pages.dev
AUTH0_DOMAIN=your-dev-tenant.auth0.com
AUTH0_CLIENT_ID=replace-me
AUTH0_AUDIENCE=https://your-render-service.onrender.com
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000001

# Backend runtime values for Render
NODE_ENV=production
DB_HOST=your-neon-host
DB_PORT=5432
DB_NAME=your_neon_db
DB_USERNAME=your_neon_user
DB_PASSWORD=replace-me
AUTH0_ISSUER=https://your-dev-tenant.auth0.com/
CORS_ORIGINS=https://secretary-frontend-dev.pages.dev
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_IDP_ISSUER=https://your-dev-tenant.auth0.com/
ADMIN_IDP_SUBJECT=auth0|replace-me
